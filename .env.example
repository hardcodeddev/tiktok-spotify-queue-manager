# Admin Authentication
ADMIN_PASSWORD=your_secure_password
SESSION_SECRET=a_long_random_string_for_signing_cookies

SPOTIFY_CLIENT_ID=your_client_id_here
# SPOTIFY_CLIENT_SECRET is not required — auth uses PKCE (no client secret needed)
SPOTIFY_CALLBACK_URL=https://yourdomain.com/auth/spotify/callback
TIKTOK_SIGN_API_KEY=   # get free key from tiktokliveconnector.com
PORT=4000
WEB_ORIGIN=https://yourdomain.com
NODE_ENV=production

# ── Firebase Authentication (viewers must sign in to request a song) ──
# Backend (Admin SDK) — provide ONE of these credential options:
#   Option A: paste the full service-account JSON on a single line
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
#   Option B: individual fields (keep the \n escapes in the private key)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Frontend (Web SDK) — these are public, baked into the build at the VITE_ prefix.
# For the production Docker build, pass them as build args (see frontend/Dockerfile).
VITE_FIREBASE_API_KEY=your_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your_web_app_id

# Dev only (not needed in production — nginx proxies socket.io to same origin)
# VITE_SOCKET_URL=http://localhost:4000
